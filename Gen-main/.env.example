# All variables below are OPTIONAL. TryGenHub runs fully without any of
# them configured — the related integration simply stays disabled.
# Never commit a real .env file; only this .env.example template is
# tracked in git.

# Canonical production site URL, used to build canonical links, the
# sitemap, robots.txt, and Open Graph URLs. Defaults to
# https://trygenhub.com if unset.
NEXT_PUBLIC_SITE_URL=https://trygenhub.com

# Google Analytics 4 Measurement ID (format: G-XXXXXXXXXX).
# Optional — defaults to the site's real GA4 property (G-7R07R4465S)
# hardcoded in lib/env.ts. Only set this to override that default
# (e.g. a different GA4 property for a staging/preview deployment,
# or an invalid value to disable Analytics there).
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Google Search Console HTML tag verification token.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Google AdSense publisher ID (format: ca-pub-XXXXXXXXXXXXXXXX).
# Optional — defaults to the site's real publisher ID (ca-pub-8094929435378990)
# hardcoded in lib/env.ts. Only set this to override that default
# (e.g. a different ID for a staging/preview deployment).
NEXT_PUBLIC_ADSENSE_CLIENT_ID=

# AdSense ad unit slot ID for the homepage placement (between the
# Statistics and WhyGenHub sections). Optional — defaults to the
# real homepage ad unit (9747695756) hardcoded in lib/env.ts. Only
# set this to override that default.
NEXT_PUBLIC_ADSENSE_SLOT_HOME=

# AdSense ad unit slot ID for generator page placements. Not yet
# configured with a default — leave unset until a dedicated ad unit
# is created for generator pages.
NEXT_PUBLIC_ADSENSE_SLOT_GENERATOR=
